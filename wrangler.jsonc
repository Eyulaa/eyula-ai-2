{
  "$schema": "https://developers.cloudflare.com/workers/wrangler/config-schema.json",
  "name": "eyula-ai-2-1",
  "compatibility_date": "2026-07-10",
  "main": "src/index.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "ai": {
    "binding": "AI"
  }
}
